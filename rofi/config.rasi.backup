configuration {
    modi: "drun";
    show-icons: true;
    icon-theme: "Papirus";
    terminal: "ghostty";
    drun-display-format: "{icon} {name}";
    location: 0;
    disable-history: false;
    hide-scrollbar: true;
    display-drun: "   Search ";
}

/* ==========================================
 * COLOR PALETTE (Catppuccin Mocha)
 * ========================================== */
* {
    bg: #1e1e2e;
    bg-alt: #313244;
    fg: #cdd6f4;
    accent: #89b4fa; /* Blue accent */
    
    background-color: @bg;
    text-color: @fg;
    font: "JetBrainsMono Nerd Font 12";
}

/* ==========================================
 * LAYOUT & STYLING
 * ========================================== */

window {
    width: 60%;
    background-color: @bg; /* Explicitly overrides the default beige background */
    border: 2px;
    border-color: @accent;
    border-radius: 10px;
    padding: 15px; 
}

mainbox {
    spacing: 1px;
}

inputbar {
    color: @fg;
    spacing: 10px;
    padding: 10px;
    background-color: @bg-alt;
    border-radius: 8px;
    children: [ prompt, entry ];
}

prompt {
    background-color: @accent;
    text-color: @bg;
    padding: 5px 10px;
    border-radius: 5px;
}

entry {
    placeholder: "Type to search apps...";
    placeholder-color: #6c7086;
    background-color: transparent;
    padding: 5px;
    text-color: inherit;
}

listview {
    lines: 8;
    columns: 1;
    spacing: 5px;
    padding: 10px 0px 0px 0px;
    fixed-height: true;
    fixed-columns: true;
}

element {
    padding: 10px;
    border-radius: 8px;
    spacing: 10px;
}

element-icon {
    size: 1.5em;
    background-color: transparent;
}

element-text {
    vertical-align: 0.5;
    background-color: transparent;
    text-color: inherit;
}

element normal.normal, element alternate.normal {
    background-color: transparent;
    text-color: @fg;
}

element selected.normal {
    background-color: @bg-alt;
    text-color: @accent;
}
