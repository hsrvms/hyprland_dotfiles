" =======================================================
" ~/.config/tridactyl/tridactylrc
" =======================================================

" --- General Settings ---
" Make hinting faster and more visible
set hintchars hjklasdfgyuiopqwertnmzxcvb
set hintuppercase true

" Smooth scrolling
set smoothscroll true

" Set your preferred external editor (triggered via <C-i> in text fields)
" This spawns a new foot window running Neovim
" set editorcmd foot -e "vim %f '+normal %lG%c|'"
" set editorcmd foot -e "zed %f '+normal %lG%c|'"

" --- Keybindings ---
" Tab navigation that aligns with standard Vim behavior
" bind J tabprev
" bind K tabnext

" Unbind the default J/K to avoid conflicts if you want strictly gT/gt
unbind J
unbind K
bind gT tabprev
bind gt tabnext

" Quickly toggle Ignore Mode (useful for Codespaces, ERPNext desk, etc.)
bind <C-z> mode ignore

" --- Custom Search Engines ---
" Format: set searchurls.[keyword] [URL]
" Usage: 'o gh frappe/erpnext' or 't aw hyprland'
set searchurls.gh https://github.com/search?q=
set searchurls.aw https://wiki.archlinux.org/index.php?search=
set searchurls.go https://pkg.go.dev/search?q=

" Make standard DuckDuckGo or Google your default
set searchengine duckduckgo

" --- Site-Specific Settings (Blacklists) ---
" Automatically enter Ignore Mode on web apps with their own heavy keybindings
blacklistadd https://github.com/codespaces/.*
blacklistadd https://discord.com/.*

" --- Visuals ---
" Hide the mode indicator if you prefer a cleaner screen (optional)
" set modeindicator false

" Set a custom theme (Tridactyl comes with dark, dark-nerd, etc.)
colorscheme dark-nerd
